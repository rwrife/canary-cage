{
  "version": 1,
  "agents": [
    {
      "agent": "claude-code",
      "display": "Claude Code (Anthropic)",
      "rules": [
        {
          "id": "claude.commit.coauthor",
          "weight": 0.45,
          "field": "commit_message",
          "pattern": "(?i)co-authored-by:\\s*claude"
        },
        {
          "id": "claude.commit.signature",
          "weight": 0.4,
          "field": "commit_message",
          "pattern": "(?i)generated with\\s+\\[?claude code\\]?"
        },
        {
          "id": "claude.author.email",
          "weight": 0.35,
          "field": "commit_author",
          "pattern": "(?i)(noreply@anthropic\\.com|claude\\[bot\\])"
        },
        {
          "id": "claude.content.phrasing",
          "weight": 0.15,
          "field": "content",
          "pattern": "(?i)\\bi'll\\b.{0,80}\\b(refactor|implement|add|update)\\b"
        },
        {
          "id": "claude.commit.bot_emoji",
          "weight": 0.2,
          "field": "commit_message",
          "pattern": "🤖.{0,30}claude"
        }
      ]
    },
    {
      "agent": "github-copilot",
      "display": "GitHub Copilot",
      "rules": [
        {
          "id": "copilot.commit.coauthor",
          "weight": 0.45,
          "field": "commit_message",
          "pattern": "(?i)co-authored-by:.*(copilot|github-copilot)"
        },
        {
          "id": "copilot.author.bot",
          "weight": 0.45,
          "field": "commit_author",
          "pattern": "(?i)(copilot-swe-agent|github-copilot\\[bot\\]|copilot\\[bot\\])"
        },
        {
          "id": "copilot.commit.tag",
          "weight": 0.35,
          "field": "commit_message",
          "pattern": "(?i)\\[copilot\\]|github copilot agent"
        },
        {
          "id": "copilot.user_agent",
          "weight": 0.5,
          "field": "user_agent",
          "pattern": "(?i)github-copilot|copilot-agent"
        },
        {
          "id": "copilot.content.marker",
          "weight": 0.2,
          "field": "content",
          "pattern": "(?i)generated by github copilot|<!--\\s*copilot"
        }
      ]
    },
    {
      "agent": "cursor",
      "display": "Cursor",
      "rules": [
        {
          "id": "cursor.commit.tag",
          "weight": 0.4,
          "field": "commit_message",
          "pattern": "(?i)\\[cursor\\]|cursor agent|generated by cursor"
        },
        {
          "id": "cursor.author",
          "weight": 0.4,
          "field": "commit_author",
          "pattern": "(?i)(cursoragent|cursor\\[bot\\]|@cursor)"
        },
        {
          "id": "cursor.repo.config",
          "weight": 0.3,
          "field": "repo_paths",
          "pattern": "(?i)(^|/)(\\.cursor/|\\.cursorrules$|cursor\\.json)"
        },
        {
          "id": "cursor.content.marker",
          "weight": 0.2,
          "field": "content",
          "pattern": "(?i)cursor-generated|//\\s*cursor:"
        },
        {
          "id": "cursor.user_agent",
          "weight": 0.5,
          "field": "user_agent",
          "pattern": "(?i)cursor/\\d|cursor-agent"
        }
      ]
    },
    {
      "agent": "codex-cli",
      "display": "OpenAI Codex CLI",
      "rules": [
        {
          "id": "codex.commit.tag",
          "weight": 0.4,
          "field": "commit_message",
          "pattern": "(?i)\\[codex\\]|codex cli|generated with codex"
        },
        {
          "id": "codex.author",
          "weight": 0.4,
          "field": "commit_author",
          "pattern": "(?i)(openai-codex|codex\\[bot\\]|codex-agent)"
        },
        {
          "id": "codex.commit.coauthor",
          "weight": 0.45,
          "field": "commit_message",
          "pattern": "(?i)co-authored-by:.*(codex|openai)"
        },
        {
          "id": "codex.repo.config",
          "weight": 0.25,
          "field": "repo_paths",
          "pattern": "(?i)(^|/)(\\.codex/|codex\\.toml$|AGENTS\\.md$)"
        },
        {
          "id": "codex.user_agent",
          "weight": 0.5,
          "field": "user_agent",
          "pattern": "(?i)codex-cli|openai-codex"
        }
      ]
    },
    {
      "agent": "generic-llm",
      "display": "Generic LLM agent",
      "rules": [
        {
          "id": "llm.commit.ai_phrase",
          "weight": 0.15,
          "field": "commit_message",
          "pattern": "(?i)(ai[- ]generated|generated by (an? )?(llm|ai))"
        },
        {
          "id": "llm.commit.emoji_header",
          "weight": 0.1,
          "field": "commit_message",
          "pattern": "^(✨|🤖|🪄|🚀)\\s"
        },
        {
          "id": "llm.content.emdash_style",
          "weight": 0.1,
          "field": "content",
          "pattern": "—.{5,80}—"
        },
        {
          "id": "llm.content.toolcall_block",
          "weight": 0.2,
          "field": "content",
          "pattern": "(?i)(<tool_call>|\\bEdit\\(file_path=|\\bWrite\\(file_path=)"
        },
        {
          "id": "llm.commit.bot_suffix",
          "weight": 0.2,
          "field": "commit_author",
          "pattern": "(?i)\\[bot\\]$"
        }
      ]
    }
  ]
}
